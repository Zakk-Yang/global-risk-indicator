// =============================================================================
// GRI Database Schema
// Architecture: 5 Drivers → 5 Risk Categories ← ~20 Indicators × 6 Regions
// Deploy with: Supabase / Neon (free PostgreSQL) + Vercel
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  IRREGULAR
}

enum RegionType {
  COUNTRY
  REGION
  BASKET
  GLOBAL
}

enum ProviderAccessType {
  PUBLIC
  API_KEY
  ACCOUNT
  LICENSED
}

enum CoverageStatus {
  OBSERVED
  CARRY_FORWARD
  ESTIMATED
  STALE
}

// =============================================================================
// Reference Tables (static config, populated via seed)
// =============================================================================

model Provider {
  id           String             @id // e.g. "fred"
  name         String // "FRED"
  accessType   ProviderAccessType @default(PUBLIC) @map("access_type")
  docsUrl      String             @default("") @map("docs_url")
  baseUrl      String             @default("") @map("base_url")
  active       Boolean            @default(true)

  series              IndicatorSeries[]

  @@map("providers")
}

model Driver {
  id          String @id // e.g. "geopolitical"
  name        String // "Geopolitical Conflict"
  color       String // "#ef4444"
  description String

  categories     DriverCategory[]
  snapshotScores SnapshotDriverScore[]

  @@map("drivers")
}

model RiskCategory {
  id   String @id // e.g. "inflation"
  name String // "Inflation Pressure"

  indicators     Indicator[]
  drivers        DriverCategory[]
  snapshotScores SnapshotCategoryScore[]

  @@map("risk_categories")
}

model Indicator {
  id         String       @id // e.g. "cpi"
  name       String // "CPI Inflation (YoY)"
  unit       String // "%", "idx"
  description String       @default("")
  categoryId String       @map("category_id")
  category   RiskCategory @relation(fields: [categoryId], references: [id])

  // Legacy/default metadata. Real production sourcing should use IndicatorSeries.
  frequency   String   @default("monthly") // "daily" | "weekly" | "monthly" | "quarterly"
  source      String   @default("") // "FRED", "OECD", "BIS", "GDELT", etc.
  sourceCode  String   @default("") @map("source_code") // API series ID (e.g. "CPIAUCSL" for FRED)
  sourceUrl   String   @default("") @map("source_url") // Direct link to data source
  lastUpdated DateTime? @map("last_updated") // When we last fetched new data
  nextExpected DateTime? @map("next_expected") // When next release is expected

  readings Reading[]
  series   IndicatorSeries[]

  @@map("indicators")
}

model Region {
  id   String @id // e.g. "us"
  name String // "United States"
  code String // "US"
  type RegionType @default(REGION)
  iso2 String?
  iso3 String?
  active Boolean @default(true)

  readings       Reading[]
  snapshotScores SnapshotRegionScore[]
  series         IndicatorSeries[]
  memberOf       RegionMembership[] @relation("RegionMembershipChild")
  members        RegionMembership[] @relation("RegionMembershipParent")

  @@map("regions")
}

model RegionMembership {
  parentRegionId String @map("parent_region_id")
  childRegionId  String @map("child_region_id")
  weight         Float?

  parent Region @relation("RegionMembershipParent", fields: [parentRegionId], references: [id], onDelete: Cascade)
  child  Region @relation("RegionMembershipChild", fields: [childRegionId], references: [id], onDelete: Cascade)

  @@id([parentRegionId, childRegionId])
  @@map("region_memberships")
}

/// Provider-specific mapping for one indicator in one region.
/// Use this when a source series differs by geography/provider; indicator-level metadata remains as the fallback/default.
model IndicatorSeries {
  id          String    @id @default(cuid())
  indicatorId String    @map("indicator_id")
  regionId    String    @map("region_id")
  providerId  String    @map("provider_id")
  dataset     String    @default("")
  seriesCode  String    @map("series_code")
  seriesLabel String?   @map("series_label")
  frequency   Frequency
  unit        String    @default("")
  sourceUrl   String?   @map("source_url")
  transform   String    @default("level") // "level", "yoy", "mom", "drawdown", etc.
  isPrimary   Boolean   @default(true) @map("is_primary")
  staleAfterHours Int?  @map("stale_after_hours")
  lastUpdated   DateTime? @map("last_updated")
  nextExpected  DateTime? @map("next_expected")
  minValue       Float?   @map("min_value")
  maxValue       Float?   @map("max_value")
  safeCenter     Float?   @map("safe_center")
  historicalMean Float?   @map("historical_mean")
  historicalStdDev Float? @map("historical_std_dev")
  inverted       Boolean?
  symmetric      Boolean?

  indicator Indicator @relation(fields: [indicatorId], references: [id])
  region    Region    @relation(fields: [regionId], references: [id])
  provider  Provider  @relation(fields: [providerId], references: [id])

  readings     Reading[]

  @@unique([indicatorId, regionId, providerId, seriesCode])
  @@index([indicatorId, regionId, isPrimary])
  @@map("indicator_series")
}

/// Driver-to-Category weight (the contribution matrix)
model DriverCategory {
  driverId   String       @map("driver_id")
  categoryId String       @map("category_id")
  weight     Float // 0-100 contribution score

  driver   Driver       @relation(fields: [driverId], references: [id])
  category RiskCategory @relation(fields: [categoryId], references: [id])

  @@id([driverId, categoryId])
  @@map("driver_category_weights")
}

// =============================================================================
// Time-Series Data (grows with each data refresh)
// =============================================================================

/// Canonical derived indicator reading per dashboard region/date.
model Reading {
  id          Int      @id @default(autoincrement())
  indicatorId String   @map("indicator_id")
  regionId    String   @map("region_id")
  seriesId    String?  @map("series_id")
  date        DateTime @db.Date
  sourceUpdatedAt DateTime? @map("source_updated_at")

  value  Float // Raw value (e.g. 3.8 for CPI)
  score  Int // Normalized risk score 0-100
  zScore Float   @map("z_score") // Z-score vs historical mean
  trend  String // "rising" | "falling" | "stable"
  coverageStatus CoverageStatus @default(OBSERVED) @map("coverage_status")
  isCarryForward Boolean @default(false) @map("is_carry_forward")
  stalenessHours Int? @map("staleness_hours")

  indicator Indicator @relation(fields: [indicatorId], references: [id])
  region    Region    @relation(fields: [regionId], references: [id])
  series    IndicatorSeries? @relation(fields: [seriesId], references: [id])

  @@unique([indicatorId, regionId, date])
  @@index([date])
  @@index([indicatorId, regionId, date(sort: Desc)]) // Latest reading per indicator/region
  @@index([seriesId, date(sort: Desc)])
  @@map("readings")
}

// =============================================================================
// Computed Snapshots (one per day, derived from readings by scoring engine)
// =============================================================================

/// Daily GRI score snapshot
model Snapshot {
  id       Int      @id @default(autoincrement())
  date     DateTime @unique @db.Date
  griScore Int      @map("gri_score") // 0-100
  griDelta Int      @map("gri_delta") // Change from previous
  regime   String // "Low Risk" | "Moderate" | "Elevated Risk" | "High Risk" | "Critical"
  event    String? // Optional event label for timeline

  driverScores   SnapshotDriverScore[]
  categoryScores SnapshotCategoryScore[]
  regionScores   SnapshotRegionScore[]

  @@index([date])
  @@map("snapshots")
}

model SnapshotDriverScore {
  id         Int @id @default(autoincrement())
  snapshotId Int @map("snapshot_id")
  driverId   String @map("driver_id")
  score      Int // 0-100
  delta      Int // Change from previous snapshot

  snapshot Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  driver   Driver   @relation(fields: [driverId], references: [id])

  @@unique([snapshotId, driverId])
  @@map("snapshot_driver_scores")
}

model SnapshotCategoryScore {
  id         Int @id @default(autoincrement())
  snapshotId Int @map("snapshot_id")
  categoryId String @map("category_id")
  score      Int // 0-100
  delta      Int // Change from previous snapshot

  snapshot Snapshot     @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  category RiskCategory @relation(fields: [categoryId], references: [id])

  @@unique([snapshotId, categoryId])
  @@map("snapshot_category_scores")
}

model SnapshotRegionScore {
  id          Int @id @default(autoincrement())
  snapshotId  Int @map("snapshot_id")
  regionId    String @map("region_id")
  score       Int // 0-100
  delta       Int
  topDriverId String @map("top_driver_id")

  snapshot Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  region   Region   @relation(fields: [regionId], references: [id])

  @@unique([snapshotId, regionId])
  @@map("snapshot_region_scores")
}

// =============================================================================
// Alerts (event-driven, created by scoring engine or manually)
// =============================================================================

model Alert {
  id          String   @id @default(cuid())
  severity    String // "critical" | "warning" | "info"
  title       String
  description String
  probability Int? // Correction probability (30d), optional
  drivers     String[] // Driver names as text array
  createdAt   DateTime @default(now()) @map("created_at")
  active      Boolean  @default(true)

  news AlertNews[]

  @@index([createdAt])
  @@index([active])
  @@map("alerts")
}

model AlertNews {
  id          Int      @id @default(autoincrement())
  alertId     String   @map("alert_id")
  title       String
  source      String // "Reuters", "Bloomberg", etc.
  url         String
  publishedAt DateTime @map("published_at")

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@map("alert_news")
}
